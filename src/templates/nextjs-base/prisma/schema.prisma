// This is your Prisma schema file
// Better Auth official schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  Free
  Freemium
  Paid
}

model User {
  id               String      @id @default(cuid())
  name             String?
  email            String      @unique
  emailVerified    Boolean     @default(false)
  image            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Plan & crédits
  accountType      AccountType @default(Free)
  subscriptionPlan String?     // "Pro" | "Team" | "Enterprise" — null si Free/Freemium
  extraCredits     Int         @default(0)

  // Rôle (admin plugin Better Auth + rôles staff)
  role             String      @default("member") // "member" | "admin" | "co-admin" | "editor" | "contributor"
  banned           Boolean     @default(false)
  banReason        String?
  banExpires       DateTime?

  posts    Post[]
  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?  // admin plugin : ID de l'admin qui impersonne
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String   @unique
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Media {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  size        Int
  mimeType    String
  description String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("media")
}

enum PostStatus {
  Draft
  PendingReview
  Published
  Scheduled
  Archived
}

model Post {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  excerpt        String?
  content        String     // Markdown
  coverImage     String?
  coverImageAlt  String?
  authorName     String     // nom affiché, éditable
  status         PostStatus @default(Draft)
  publishedAt    DateTime?
  readingTime    Int?       // minutes, auto-calculé
  seoTitle       String?
  seoDescription String?

  authorId   String
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags       Tag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("post")
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  parentId    String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("SubCategories")
  posts    Post[]

  createdAt DateTime @default(now())

  @@map("category")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]

  @@map("tag")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   // "co-admin" | "editor" | "contributor"
  token     String   @unique @default(cuid())
  invitedBy String   // userId du super admin
  expiresAt DateTime
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("invitation")
}
